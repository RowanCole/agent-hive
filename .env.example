# ── Agent Hive 环境配置 ──
# 复制此文件为 .env 并填入实际值
# AgentConfig 会自动加载 .env 中的变量

# ── 必填：MasterAgent LLM 配置（兼容 OpenAI / DeepSeek 等任意 OpenAI 兼容 API） ──
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ── 可选：WorkerAgent 独立 LLM（不设则复用上方 Master 配置） ──
# WORKER_AGENT_URL=https://worker-api-endpoint/v1
# WORKER_AGENT_KEY=your_worker_key_here
# WORKER_LLM_MODEL=worker-model-name
